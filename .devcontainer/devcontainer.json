{
  "name": "Storage Planner",
  "postCreateCommand": "npm install",
  "postStartCommand": "sleep 5 && cd /workspaces/storage-planning && npm run dev --workspace=server > /tmp/server.log 2>&1 &",
  "forwardPorts": [3001],
  "portsAttributes": {
    "3001": {
      "visibility": "public",
      "label": "Storage Planner",
      "onAutoForward": "silent"
    }
  }
}
