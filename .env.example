# ── Server env vars ───────────────────────────────────────────────────────────

# Port the Fastify server listens on
PORT=3001

# GitHub OAuth app credentials (from github.com/settings/developers — see DEPLOY.md).
# When NOT set, the server falls back to DEV_USER for local development.
GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Full public URL of this deployment (used as the OAuth redirect_uri base).
# In local dev this is not needed — the server uses http://localhost:3001 as default.
APP_URL=https://storage-planner.internal.roblox.com

# Your rosId — seeded as the first admin on first boot.
# Must match a person whose email equals your @roblox.com GitHub-verified email.
FIRST_ADMIN_ROS_ID=ros_sara_m

# Dev-only: impersonate this rosId for all requests when GITHUB_CLIENT_ID is not set.
DEV_USER=ros_sara_m

# Set to "false" to skip fixture org data and require real ROS API sync
USE_FIXTURE_ROS=true

# SQLite database file path (relative to server working directory)
DATABASE_URL=data/storage_planner.db
