# ── Server env vars ───────────────────────────────────────────────────────────

# Port the Fastify server listens on
PORT=3001

# Your @roblox.com email — seeded as the first admin on first boot.
FIRST_ADMIN_EMAIL=you@roblox.com

# Dev-only: impersonate this rosId when no x-user-email header is sent.
DEV_USER=ros_sara_m

# Set to "false" to skip fixture org data and require real ROS API sync
USE_FIXTURE_ROS=true

# SQLite database file path (relative to server working directory)
DATABASE_URL=data/storage_planner.db
